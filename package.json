{
  "name": "discord-bot-starter",
  "version": "1.0.0",
  "description": "Production-ready Discord bot template with CI/CD and one-click deployment",
  "main": "src/index.js",
  "private": true,
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "deploy-commands": "node scripts/deploy-commands.js",
    "lint": "eslint src/",
    "test": "jest --verbose --coverage",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major"
  },
  "dependencies": {
    "discord.js": "^14.26.3",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "jest": "^30.3.0"
  },
  "jest": {
    "coverageThreshold": {
      "global": {
        "statements": 70,
        "branches": 50,
        "functions": 65,
        "lines": 70
      }
    },
    "coverageReporters": [
      "text",
      "text-summary",
      "json-summary"
    ]
  },
  "engines": {
    "node": ">=22"
  }
}
